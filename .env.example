# Copy to .env and fill in. .env is gitignored (never commit real keys).

# Generation backend: "stub" (free local FFmpeg) or "cosmos" (NVIDIA Cosmos 3).
LIVEHERE_BACKEND=stub

# --- Cosmos 3 endpoint (used when LIVEHERE_BACKEND=cosmos) ---
# Two supported API styles (auto-detected from the URL, or force with
# COSMOS_API_STYLE):
#
#   nvidia_infer  → NVIDIA-hosted free endpoint (build.nvidia.com)
#     COSMOS_BASE_URL=https://ai.api.nvidia.com/v1
#     COSMOS_INFER_PATH=/infer
#   vllm_omni     → self-hosted vLLM-Omni server (RunPod/Modal/Nebius/local)
#     COSMOS_BASE_URL=http://<host>:8000/v1
#     COSMOS_VIDEOS_PATH=/videos/sync
COSMOS_BASE_URL=
COSMOS_API_KEY=            # secret; NVIDIA keys start with "nvapi-"
COSMOS_MODEL=nvidia/Cosmos3-Nano
COSMOS_API_STYLE=auto      # auto | nvidia_infer | vllm_omni
COSMOS_INFER_PATH=/infer
COSMOS_VIDEOS_PATH=/videos/sync

# --- Cosmos generation params (realism preset: faithful to the photo) ---
COSMOS_NUM_FRAMES=97
COSMOS_FPS=24
COSMOS_STEPS=50              # more steps = cleaner, less artifacting
COSMOS_GUIDANCE=4.0         # LOWER = more faithful to the photo (less hallucination)
COSMOS_FLOW_SHIFT=7.0       # LOWER = smaller, steadier motion (less drift)
COSMOS_RESOLUTION=720_16_9   # nvidia_infer
COSMOS_SIZE=1280x720         # vllm_omni
# COSMOS_NEGATIVE_PROMPT / COSMOS_FIDELITY_SUFFIX can be overridden too (see config.py)

# --- GPT-4o director (vision): plans the storyboard / listing trailer ---
OPENAI_API_KEY=              # secret; OpenAI keys start with "sk-"
OPENAI_MODEL=gpt-4o

# Tavily — hackathon search partner (location / nearby lookups).
# Badge in the UI shows "connected" when set. Keys start with "tvly-".
TAVILY_API_KEY=             # secret
DIRECTOR_TARGET_BEATS=7

# --- Mode: "trailer" (vertical 9:16 listing promo) or "day" (16:9 day-in-life) ---
LIVEHERE_MODE=trailer
TRAILER_WIDTH=1920
TRAILER_HEIGHT=1080
TRAILER_TARGET_BEATS=6
TTS_MODEL=gpt-4o-mini-tts    # OpenAI text-to-speech for the voiceover
TTS_VOICE=nova
MUSIC_VOLUME=0.16
# MUSIC_PATH=                # optional custom music bed; else a soft pad is synthesized
